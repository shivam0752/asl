{
  "expo": {
    "name": "LevelUp",
    "slug": "levelup",
    "version": "1.0.0",
    "scheme": "aetherls",
    "userInterfaceStyle": "dark",
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-secure-store",
        {
          "faceIDPermission": "Allow LevelUp to access Face ID."
        }
      ],
      "expo-web-browser"
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#0D0D0D"
      },
      "package": "com.shivam.levelup"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.shivam.levelup",
      "userInterfaceStyle": "dark"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "92fcd4f7-3179-48dd-851f-7a85d7e6b784"
      }
    }
  }
}
