{
  "expo": {
    "name": "LevelUp",
    "slug": "levelup",
    "version": "1.0.0",
    "scheme": "aetherls",
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-secure-store",
        {
          "faceIDPermission": "Allow LevelUp to access Face ID."
        }
      ],
      "expo-web-browser"
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0D0D0D"
      },
      "package": "com.shivam.levelup"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.shivam.levelup"
    }
  }
}
